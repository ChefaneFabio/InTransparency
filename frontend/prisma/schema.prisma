  accentColor  String?

  // Park Details
  memberCompanyCount Int       @default(0)
  focusAreas         String[]  @default([]) // e.g. ["Industry 4.0", "AI", "Biotech"]
  foundedYear        Int?

  // Notification Preferences
  notifyNewStudents       Boolean @default(true)
  notifyRecruiterActivity Boolean @default(true)
  notifyPlacements        Boolean @default(true)

