  FAILED
}

// ============================================
// RECRUITER FEATURES MODELS
// ============================================

// Saved Candidates (recruiter bookmarks)
model SavedCandidate {
  id          String   @id @default(cuid())
  recruiterId String
  recruiter   User     @relation("RecruiterSavedCandidates", fields: [recruiterId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   User     @relation("SavedCandidateProfile", fields: [candidateId], references: [id], onDelete: Cascade)

  folder    String   @default("all")
  notes     String?  @db.Text
  rating    Int?
  tags      String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recruiterId, candidateId])
  @@index([recruiterId])
  @@index([candidateId])
  @@index([folder])
}

// Saved Searches (recruiter search presets)
model SavedSearch {
  id          String  @id @default(cuid())
  recruiterId String
  recruiter   User    @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  name           String
  description    String?
  filters        Json
  isActive       Boolean  @default(true)
  alertsEnabled  Boolean  @default(false)
  alertFrequency String   @default("daily")
  candidateCount Int      @default(0)
  newMatches     Int      @default(0)
  lastRunAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recruiterId])
}

// Recruiter Settings (company profile & notification prefs)
model RecruiterSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Company Profile
  companyName        String?
  companyWebsite     String?
  companyIndustry    String?
  companySize        String?
  companyLocation    String?
  companyDescription String? @db.Text
  companyLogo        String?

  // Notification Preferences
  notifyNewApplications Boolean @default(true)
  notifyMessages        Boolean @default(true)
  notifySearchAlerts    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Contact Credit Payment (pay-per-contact model)
model ContactPayment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  email  String

  // Payment Details
  amount   Int // in cents (€10 = 1000 per contact credit)
  currency String @default("eur")
  credits  Int // number of contact credits purchased

  // Stripe
  stripePaymentIntentId String? @unique
  stripeSessionId       String? @unique
  stripeCustomerId      String?

  // Status
  status PaymentStatus @default(PENDING)

  // Metadata
  metadata Json?

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  paidAt    DateTime?

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([stripePaymentIntentId])
}

// ============================================
// MULTI-CAMPUS SUPPORT (Enterprise)
// ============================================

model Campus {
  id        String @id @default(cuid())
  userId    String // The university admin who owns this campus
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String  // e.g., "Milano - Bovisa", "Milano - Leonardo"
  code      String? // Internal campus code
  city      String
  region    String?
  address   String?
  country   String  @default("IT")

  // Campus-specific settings
  contactEmail String?
  contactPhone String?
  departments  String[] @default([])

  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

// ============================================
// API KEY MANAGEMENT (Enterprise)
// ============================================

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String   // e.g., "Production Key", "Staging Key"
  keyHash   String   @unique // SHA-256 hash of the API key
  keyPrefix String   // First 8 chars of key for display (e.g., "itk_abc1...")

  scopes    String[] @default(["read"]) // "read", "write", "export"

  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([keyHash])
}

// ============================================
// MOAT FEATURES: Skills Translation + Prediction + Badges + Decision Packs
// ============================================

// SkillMapping — academic term <-> industry term mapping
model SkillMapping {
  id String @id @default(cuid())

  // Academic term (what students write)
  academicTerm String

  // Industry equivalents
  industryTerms String[] @default([]) // ["Predictive Maintenance", "Condition Monitoring"]
  synonyms      String[] @default([]) // Alternate phrasings

  // Ontology
  parentId String?       // For hierarchy (e.g., "ML" parent of "Predictive Maintenance ML")
  parent   SkillMapping? @relation("SkillHierarchy", fields: [parentId], references: [id])
  children SkillMapping[] @relation("SkillHierarchy")

  // Metadata
  locale      String  @default("en") // ISO 639-1
  demandScore Int     @default(0)    // 0-100, computed from Job frequency
  aiGenerated Boolean @default(false)
  verified    Boolean @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([academicTerm, locale])
  @@index([locale])
  @@index([demandScore])
  @@index([parentId])
}

// PlacementPrediction — per-student placement probability cache
model PlacementPrediction {
  id        String @id @default(cuid())
  studentId String
  student   User   @relation("StudentPredictions", fields: [studentId], references: [id], onDelete: Cascade)

  // Prediction
  probability   Float // 0.0 - 0.99
  signalWeights Json  // { signal: weight } breakdown
  signalValues  Json  // { signal: rawValue } used in computation
  topFactors    Json  // [{ factor, impact, description }] top 3-5

  // Cache management
  generatedAt DateTime @default(now())
  expiresAt   DateTime // 48h TTL

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([expiresAt])
}

// DecisionPack — recruiter <-> candidate hiring dossier cache
model DecisionPack {
  id          String @id @default(cuid())
  recruiterId String
  recruiter   User   @relation("RecruiterDecisionPacks", fields: [recruiterId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   User   @relation("CandidateDecisionPacks", fields: [candidateId], references: [id], onDelete: Cascade)

  // Optional job context
  jobId String?

  // Dossier content (cached JSON)
  content    Json   // Full dossier: profile, skills, projects, endorsements, grades, prediction
  matchScore Float? // 0-100 match confidence vs job (if jobId provided)
  pdfUrl     String?

  // Cache management
  generatedAt DateTime @default(now())
  expiresAt   DateTime // 7-day TTL

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recruiterId, candidateId, jobId])
  @@index([recruiterId])
  @@index([candidateId])
  @@index([expiresAt])
}

// PortableBadge — per-project verification badge for external sharing
model PortableBadge {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Verification hash
  contentHash String // SHA-256 of project content at badge issuance time

  // Open Badges 3.0 metadata
  ob3Metadata Json? // JSON-LD VerifiableCredential payload

  // Stats
  viewCount   Int @default(0)
  exportCount Int @default(0)

  // Issuance
  issuedAt  DateTime @default(now())
  issuedBy  String?  // userId of issuer (project owner or university admin)
  revokedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([contentHash])
}

// InstitutionPartnership — bilateral agreement between universities/ITS for student exchange
model InstitutionPartnership {
  id String @id @default(cuid())

  // Initiating institution
  institutionAId String
  institutionA   UniversitySettings @relation("PartnershipA", fields: [institutionAId], references: [id], onDelete: Cascade)

  // Partner institution
  institutionBId String
  institutionB   UniversitySettings @relation("PartnershipB", fields: [institutionBId], references: [id], onDelete: Cascade)

  // Partnership details
  status        String  @default("PENDING") // PENDING, ACTIVE, EXPIRED, REVOKED
  exchangeType  String  @default("BILATERAL") // BILATERAL, UNIDIRECTIONAL
  maxStudents   Int?    // Max students per academic year per direction
  startDate     DateTime?
  endDate       DateTime?
  notes         String?

  // Course equivalencies under this partnership
  courseEquivalencies   CourseEquivalency[]
  exchangeEnrollments  ExchangeEnrollment[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([institutionAId, institutionBId])
  @@index([institutionAId])
  @@index([institutionBId])
  @@index([status])
}

// CourseEquivalency — maps courses between partner institutions
model CourseEquivalency {
  id String @id @default(cuid())

  partnershipId String
  partnership   InstitutionPartnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)

  // Source course
  sourceCourseId   String?
  sourceCourse     Course? @relation("SourceEquivalency", fields: [sourceCourseId], references: [id])
  sourceCourseName String  // Denormalized for display when course isn't in DB

  // Equivalent course at partner institution
  targetCourseId   String?
  targetCourse     Course? @relation("TargetEquivalency", fields: [targetCourseId], references: [id])
  targetCourseName String

  // ECTS credit mapping
  sourceCredits Int?
  targetCredits Int?

  // Approval
  approved    Boolean @default(false)
  approvedBy  String?
  approvedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partnershipId])
  @@index([sourceCourseId])
  @@index([targetCourseId])
}

// ─── Feature 1: Student-to-Student Mentoring ─────────────────────────────────

model MentorshipConnection {
  id String @id @default(cuid())

  mentorId String
  mentor   User   @relation("Mentor", fields: [mentorId], references: [id], onDelete: Cascade)

  menteeId String
  mentee   User   @relation("Mentee", fields: [menteeId], references: [id], onDelete: Cascade)

  // Status flow: PENDING → ACTIVE → COMPLETED / DECLINED / CANCELLED
  status     String @default("PENDING")
  message    String? @db.Text // Initial request message from mentee

  // Mentoring context
  topics     String[] @default([]) // e.g. ["thesis", "career", "skills"]
  university String?              // Shared institution

  // Tracking
  startedAt    DateTime?
  completedAt  DateTime?
  mentorRating Int?      // 1-5 rating by mentee
  menteeRating Int?      // 1-5 rating by mentor
  feedback     String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mentorId, menteeId])
  @@index([mentorId])
  @@index([menteeId])
  @@index([status])
  @@index([university])
}

// ─── Feature 2: Employer Reviews & Ratings ───────────────────────────────────

model EmployerReview {
  id String @id @default(cuid())

  reviewerId String
  reviewer   User   @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  // Employer being reviewed
  companyName  String
  companyId    String?  // Links to recruiter user ID if on platform
  jobTitle     String?  // Role held during placement
  department   String?

  // Placement context
  placementId  String?  // Optional link to Placement record
  startDate    DateTime?
  endDate      DateTime?
  isCurrentRole Boolean @default(false)

  // Ratings (1-5)
  overallRating       Int
  workLifeBalance     Int?
  mentorship          Int?
  learningOpportunity Int?
  compensation        Int?
  cultureFit          Int?

  // Written review
  title       String?
  reviewText  String   @db.Text
  pros        String?  @db.Text
  cons        String?  @db.Text

  // Moderation
  isAnonymous Boolean @default(false)
  isVerified  Boolean @default(false) // Verified via placement record
  isPublished Boolean @default(true)
  flagged     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewerId])
  @@index([companyName])
  @@index([companyId])
  @@index([overallRating])
}

// ─── Feature 3: Skills Gap Report (cached per university) ────────────────────

model SkillGapReport {
  id String @id @default(cuid())

  universitySettingsId String
  university           UniversitySettings @relation(fields: [universitySettingsId], references: [id], onDelete: Cascade)

  // Report data (JSON blobs for flexibility)
  studentSkills   Json   // { skill: count } — skills present in student projects
  marketDemand    Json   // { skill: demandScore } — from SkillMapping + Job data
  gaps            Json   // [{ skill, demandScore, studentCount, gapSeverity }]
  strengths       Json   // [{ skill, demandScore, studentCount }] — where supply > demand
  recommendations Json?  // AI-generated recommendations

  // Metadata
  studentCount Int    // Students analyzed
  jobCount     Int    // Jobs analyzed
  generatedAt  DateTime @default(now())
  expiresAt    DateTime // Cache TTL

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([universitySettingsId])
  @@index([expiresAt])
}

// ─── Feature 4: Automated Portfolio Score (Trust Score) ──────────────────────

model PortfolioScore {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Overall score (0-100)
  score Int

  // Component scores (0-100 each)
  verificationScore  Int  // % of projects verified
  endorsementScore   Int  // Quality + quantity of endorsements
  completenessScore  Int  // Profile completeness
  aiAnalysisScore    Int  // Average AI analysis scores
  activityScore      Int  // Recency + engagement
  predictionScore    Int  // Placement prediction mapped to 0-100

  // Weights used (for transparency)
  weights Json

  // Badge level derived from score
  badgeLevel String // BRONZE (0-39), SILVER (40-59), GOLD (60-79), PLATINUM (80-100)

  generatedAt DateTime @default(now())
  expiresAt   DateTime // 24h cache

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([score])
  @@index([expiresAt])
}

// ─── Feature 5: Event / Career Day Management ───────────────────────────────

model CareerEvent {
  id String @id @default(cuid())

  // Organizer (university/institution user)
  organizerId String
  organizer   UniversitySettings @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  // Event details
  title       String
  description String?  @db.Text
  eventType   String   @default("CAREER_DAY") // CAREER_DAY, WORKSHOP, WEBINAR, NETWORKING, INFO_SESSION
  location    String?  // Physical location or "Online"
  isOnline    Boolean  @default(false)
  meetingUrl  String?  // Zoom/Teams link for online events

  // Schedule
  startDate DateTime
  endDate   DateTime
  timezone  String   @default("Europe/Rome")

  // Capacity
  maxAttendees    Int?
  maxRecruiters   Int?

  // Status
  status      String @default("DRAFT") // DRAFT, PUBLISHED, CANCELLED, COMPLETED
  publishedAt DateTime?

  // Registration
  registrationDeadline DateTime?
  requiresApproval     Boolean @default(false)

  // Relations
  rsvps EventRSVP[]
  slots EventSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizerId])
  @@index([startDate])
  @@index([status])
}

model EventRSVP {
  id String @id @default(cuid())

  eventId String
  event   CareerEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // RSVP type
  role    String // RECRUITER, STUDENT
  status  String @default("PENDING") // PENDING, CONFIRMED, DECLINED, WAITLISTED, CANCELLED

  // Recruiter-specific
  companyName  String?
  boothRequest Boolean @default(false)

  // Notes
  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([status])
}

model EventSlot {
  id String @id @default(cuid())

  eventId String
  event   CareerEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Slot details
  title       String  // e.g. "1-on-1 with Google", "Resume Review"
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String? // Room/booth number
  capacity    Int     @default(1)

  // Recruiter hosting the slot (optional)
  recruiterId String?

  // Students who booked
  bookedById  String?
  bookedBy    User?   @relation("SlotBookedBy", fields: [bookedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@index([startTime])
  @@index([bookedById])
}

// ─── Feature 6: Notification System ──────────────────────────────────────────

model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content
  type    String  // VERIFICATION_UPDATE, MESSAGE_RECEIVED, BADGE_ISSUED, MENTORSHIP_REQUEST, EVENT_RSVP, REVIEW_POSTED, SCORE_UPDATE, GENERAL
  title   String
  body    String  @db.Text
  link    String? // Deep link to relevant page

  // Status
  read      Boolean  @default(false)
  readAt    DateTime?
  dismissed Boolean  @default(false)

  // Grouping
  groupKey String? // For batching related notifications (e.g. "project:abc:verification")

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([type])
  @@index([groupKey])
}

// Exchange / Erasmus Enrollment
model ExchangeEnrollment {
  id String @id @default(cuid())

  // Student
  studentId String
  student   User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Universities
  homeUniversityName String
  homeCountry        String // ISO 3166-1 alpha-2
  hostUniversityName String
  hostCountry        String // ISO 3166-1 alpha-2

  // Program
  programType String @default("ERASMUS") // ERASMUS, BILATERAL, FREE_MOVER
  startDate   DateTime
  endDate     DateTime?
  status      String @default("PLANNED") // PLANNED, ACTIVE, COMPLETED, CANCELLED

  // Partnership link (optional)
  partnershipId String?
  partnership   InstitutionPartnership? @relation(fields: [partnershipId], references: [id])

  // Verification
  verifiedByHome Boolean @default(false)
  verifiedByHost Boolean @default(false)
  verificationDoc String? // URL to uploaded verification document

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([homeUniversityName])
  @@index([hostUniversityName])
  @@index([status])
}

// Hiring Confirmation Flow — student confirms whether they were hired after contact
model HiringConfirmation {
  id              String   @id @default(cuid())
  contactUsageId  String
  studentId       String
  recruiterId     String
  companyName     String

  // Confirmation
  status          HiringConfirmationStatus @default(PENDING)
  confirmedHired  Boolean?
  jobTitle        String?
  startDate       DateTime?
  feedback        String?  @db.Text

  // Timing
  contactDate     DateTime
  promptAfterDays Int      @default(60)
  promptSentAt    DateTime?
  respondedAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  contactUsage    ContactUsage @relation(fields: [contactUsageId], references: [id], onDelete: Cascade)
  student         User         @relation("StudentHiringConfirmations", fields: [studentId], references: [id], onDelete: Cascade)
  recruiter       User         @relation("RecruiterHiringConfirmations", fields: [recruiterId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@index([contactDate])
}

enum HiringConfirmationStatus {
  PENDING
  PROMPTED
  CONFIRMED_HIRED
  CONFIRMED_NOT_HIRED
  EXPIRED
}

// Position Listing Model (Pay-Per-Position for SME/PMI)
model PositionListing {
  id          String @id @default(cuid())
  recruiterId String
  recruiter   User   @relation("RecruiterPositions", fields: [recruiterId], references: [id], onDelete: Cascade)

  // Position details
  title       String
  description String? @db.Text
  jobId       String? // optional link to Job model

  // Pricing
  price    Int    // in cents (e.g., 4900 = €49, 9900 = €99)
  currency String @default("eur")

  // Duration
  activatedAt  DateTime?
  expiresAt    DateTime?
  durationDays Int       @default(30)

  // Status
  status PositionListingStatus @default(PENDING_PAYMENT)

  // Stripe
  stripePaymentIntentId String? @unique
  stripeSessionId       String? @unique

  // Usage
  contactsUsed Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recruiterId])
  @@index([status])
  @@index([expiresAt])
}

enum PositionListingStatus {
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  CANCELLED
}

// AI Shortlist Model — stores recruiter role postings and auto-matched candidates
model AiShortlist {
  id          String   @id @default(cuid())
  recruiterId String
  recruiter   User     @relation("RecruiterAiShortlists", fields: [recruiterId], references: [id], onDelete: Cascade)

  title       String
  description String   @db.Text
  skills      Json     // string[] of requested skills
  location    String?
  minGrade    Float?   // optional minimum normalizedGrade (0-100)
  results     Json?    // cached top matches [{id, name, score, reasons, ...}]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([recruiterId])
  @@index([createdAt])
}
