// ============================================
// MULTI-CAMPUS SUPPORT (Enterprise)
// ============================================

model Campus {
  id        String @id @default(cuid())
  userId    String // The university admin who owns this campus
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String  // e.g., "Milano - Bovisa", "Milano - Leonardo"
  code      String? // Internal campus code
  city      String
  region    String?
  address   String?
  country   String  @default("IT")

  // Campus-specific settings
  contactEmail String?
  contactPhone String?
  departments  String[] @default([])

  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

// ============================================
// API KEY MANAGEMENT (Enterprise)
// ============================================

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String   // e.g., "Production Key", "Staging Key"
  keyHash   String   @unique // SHA-256 hash of the API key
  keyPrefix String   // First 8 chars of key for display (e.g., "itk_abc1...")

  scopes    String[] @default(["read"]) // "read", "write", "export"

  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([keyHash])
