// ─── Stage Journal (Weekly Reflections) ─────────────────────────
model StageJournal {
  id        String   @id @default(cuid())
  stageId   String
  studentId String
  weekNumber Int     // 1, 2, 3...

  // What happened
  activitiesSummary  String  @db.Text // "What did you work on this week?"
  biggestChallenge   String? @db.Text // "What was your biggest challenge?"
  biggestWin         String? @db.Text // "What are you most proud of?"

  // Skills & preparation
  skillPracticed      String?  // Primary skill used this week
  newSkillLearned     String?  // Something new
  courseConnection     String?  // "Which university course was most relevant?"
  preparednessRating  Int?     // 1-5: "How prepared did you feel?"
  independenceRating  Int?     // 1-5: 1=need constant guidance, 5=fully autonomous

  // Wellbeing & adaptation
  confidenceLevel     Int?     // 1-5
  teamIntegration     Int?     // 1-5: "How integrated do you feel in the team?"
  workLifeBalance     Int?     // 1-5
  overallSatisfaction Int?     // 1-5

  // Open reflection
  whatWouldChange   String? @db.Text // "If you could change one thing..."
  adviceForNextIntern String? @db.Text // "What would you tell the next intern?"

  // Supervisor quick feedback (optional)
  supervisorComment String? @db.Text
  supervisorRating  Int?    // 1-5 for this week

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([stageId, weekNumber])
  @@index([stageId])
  @@index([studentId])
}

// ─── Stage Convention (formal agreement university-company-student) ──
model StageConvention {
  id               String   @id @default(cuid())
  universityName   String
  createdBy        String   // university admin user ID

  // Company
  companyName      String
  companyAddress   String?
  companyVAT       String?  // Partita IVA
  companyContact   String?  // Legal representative name
  companyEmail     String?
  companyPhone     String?

  // University
  universityContact String? // Tutor accademico
  universityEmail   String?

  // Student (optional — convention can cover multiple students)
  studentId         String?
  studentName       String?

  // Convention details
  conventionType    String  @default("TIROCINIO_CURRICULARE") // TIROCINIO_CURRICULARE, TIROCINIO_EXTRACURRICULARE, APPRENDISTATO, STAGE_ESTIVO
  objectives        String? @db.Text  // Training objectives / Obiettivi formativi
  activities        String? @db.Text  // Planned activities
  department        String?           // Company department
  hoursPerWeek      Int?
  totalHours        Int?
  startDate         DateTime?
  endDate           DateTime?

  // Insurance & compliance
  insuranceINAIL    String?  // INAIL position number
  insuranceRCT      String?  // RC terzi policy
  ccnlReference     String?  // Applicable CCNL

  // Signatures & status
  status            ConventionStatus @default(DRAFT)
  signedByUniversity  Boolean @default(false)
  signedByCompany     Boolean @default(false)
  signedByStudent     Boolean @default(false)
  universitySignDate  DateTime?
  companySignDate     DateTime?
  studentSignDate     DateTime?

  // Document
  documentUrl       String?  // Generated PDF URL
  notes             String?  @db.Text

  // Link to stage experience
  stageExperienceId String?  @unique

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([universityName])
  @@index([companyName])
  @@index([status])
  @@index([createdBy])
}

enum ConventionStatus {
  DRAFT
  PENDING_SIGNATURES
  ACTIVE
  COMPLETED
  EXPIRED
  REVOKED
}

enum StageType {
  CURRICULARE       // Part of degree program (CFU credits)
  EXTRACURRICULARE  // Voluntary, no credits
  APPRENDISTATO     // Apprenticeship contract
  TIROCINIO_POST    // Post-graduation internship
}

enum StageStatus {
  PENDING     // Waiting to start
  ACTIVE      // Currently ongoing
  COMPLETED   // Finished, awaiting evaluation
  EVALUATED   // Supervisor evaluation received
  VERIFIED    // University verified
  CANCELLED
}

