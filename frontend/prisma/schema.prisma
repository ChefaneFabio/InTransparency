// Outreach Templates (recruiter email sequences)
model OutreachTemplate {
  id          String   @id @default(cuid())
  recruiterId String
  name        String
  steps       Json     // Array of {type: 'intro'|'followUp'|'final', subject: string, body: string, delayDays: number}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recruiter User                @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  sequences OutreachSequence[]

  @@index([recruiterId])
}

// A running outreach sequence: a template snapshot + a candidate + where we are in it.
// A cron endpoint walks ACTIVE sequences with nextSendAt <= now() and delivers the next step.
model OutreachSequence {
  id             String                 @id @default(cuid())
  recruiterId    String
  candidateId    String
  templateId     String?
  templateName   String                 // snapshot — template can be deleted
  steps          Json                   // snapshot of steps at sequence-start time
  currentStepIdx Int                    @default(0)
  status         OutreachSequenceStatus @default(ACTIVE)
  lastSentAt     DateTime?
  nextSendAt     DateTime?              // when currentStepIdx should be delivered
  events         Json                   @default("[]") // [{ stepIdx, sentAt, messageId? }]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  recruiter User              @relation("RecruiterOutreachSequences", fields: [recruiterId], references: [id], onDelete: Cascade)
  candidate User              @relation("CandidateOutreachSequences", fields: [candidateId], references: [id], onDelete: Cascade)
  template  OutreachTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([recruiterId, status])
  @@index([nextSendAt, status])
  @@index([candidateId])
}

enum OutreachSequenceStatus {
  ACTIVE
  PAUSED
  COMPLETED
  REPLIED
  BOUNCED
}

