  PARTNERSHIP        // University partnerships, agency agreements
  OTHER
}

enum DocumentCategory {
  ACCREDITATION      // Accreditation certificates, quality reports
  STUDENT_REPORT     // Placement reports, performance analytics, graduation stats
  ACADEMIC           // Syllabi, curricula, program guides
  PARTNERSHIP        // MoUs, internship agreements, company contracts
  FINANCIAL          // Grant applications, budget reports, funding docs
  COMPLIANCE         // GDPR, data protection, audit reports
  INTERNAL           // Strategic plans, meeting minutes, annual reports
  OTHER
}

// ============================================
// Agent infrastructure — webhooks + watchlists. Supports AI agent workflows
// where recruiters want long-running queries and push notifications rather
// than only on-demand reads.
// ============================================

model WebhookSubscription {
  id         String   @id @default(cuid())
  ownerId    String   // User who owns the subscription
  url        String   // HTTPS delivery target
  secret     String   // HMAC-SHA256 secret — never returned after creation

  events     String[] @default([]) // e.g. ["match.created", "credential.issued", "stage.completed", "exchange.completed"]
  active     Boolean  @default(true)

  // Delivery health
  lastDeliveryAt  DateTime?
  lastSuccessAt   DateTime?
  lastFailureAt   DateTime?
  consecutiveFailures Int @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([ownerId])
  @@index([active])
}

model WebhookDelivery {
  id             String   @id @default(cuid())
  subscriptionId String
  eventType      String
  eventId        String   // Idempotency key
  payload        Json
  attemptCount   Int      @default(0)
  deliveredAt    DateTime?
  responseStatus Int?
  responseBody   String?  @db.Text
  lastError      String?  @db.Text
  nextRetryAt    DateTime?

  createdAt      DateTime @default(now())

  @@index([subscriptionId, createdAt])
  @@index([eventType])
  @@index([nextRetryAt])
}

model AgentWatchlist {
  id        String   @id @default(cuid())
  ownerId   String   // User (typically a recruiter) who saved this
  name      String
  // Serialized query — what the agent is watching for
  query     Json     // e.g. { type: 'candidate-match', requiredSkills: [...], jobId: '...' }
  // Optional: the webhook subscription to trigger when matches appear
  webhookSubscriptionId String?
  active    Boolean  @default(true)
  lastRunAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, active])
}

// ============================================
// AuditLog — for GDPR Art. 5(2) accountability + AI Act Art. 12 traceability.
// Records sensitive reads and any admin / moderation action.
// ============================================
model AuditLog {
  id String @id @default(cuid())

  actorId    String?
  actorEmail String?
  actorRole  String? // Snapshotted at time of action

  action     String // "READ_USER_DATA", "DELETE_USER", "OVERRIDE_MATCH", "REVOKE_CREDENTIAL", etc.
  targetType String? // "User", "MatchExplanation", "VerifiableCredential", ...
  targetId   String?

  // Structured context — IP, user-agent, request path, reason
  context    Json?

  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// ============================================
// P2 — AI Matching Explainability (AI Act native)
// ============================================

// MatchExplanation — persisted audit trail of why a match was computed
// Same record serves three audiences: student (why matched), university (fairness audit),
// recruiter (evidence-backed rationale). Immutable after write.
model MatchExplanation {
  id String @id @default(cuid())

  // Match subject and counterparty
  subjectId   String
  subject     User   @relation("MatchExplanationSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  subjectType String // "STUDENT" | "CANDIDATE"

  counterpartyId   String
  counterparty     User   @relation("MatchExplanationCounterparty", fields: [counterpartyId], references: [id], onDelete: Cascade)
  counterpartyType String // "RECRUITER" | "JOB"

  // Context (optional — e.g. a specific job posting)
  contextType String? // "JOB" | "STAGE" | "GENERIC"
  contextId   String?

  // The explanation
  matchScore   Float  // 0-100 final score
  decisionLabel String? // "STRONG_MATCH", "MATCH", "WEAK_MATCH", "NO_MATCH"

  // Structured factors — every factor contributing to the score
  factors Json // [{ name, category, weight, value, evidence[], contribution }]

  // Model metadata for auditability
  modelVersion  String   // e.g. "talent-match-v1.2.0"
  modelType     String   // e.g. "rule-based" | "hybrid" | "llm-assisted"
  inputSnapshot Json?    // Sanitized inputs used (skills, filters, etc.)

  // Human-oversight / override
  reviewed       Boolean   @default(false)
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewOutcome  String?   // "CONFIRMED" | "OVERRIDDEN" | "FLAGGED"
  reviewNotes    String?   @db.Text

  // Right to explanation — has the subject seen it?
  subjectViewed   Boolean   @default(false)
  subjectViewedAt DateTime?

  createdAt DateTime @default(now())

  @@index([subjectId])
  @@index([counterpartyId])
  @@index([contextType, contextId])
  @@index([createdAt])
}

// ============================================
// P3 — Skills Gap v2 (program-level, temporal)
// ============================================

// SkillGapTrend — monthly snapshots per university × program
// Enables heatmap visualizations and trend lines
model SkillGapTrend {
  id             String   @id @default(cuid())
  universityName String
  programName    String?  // Null = university-wide; otherwise "Computer Science BSc", etc.
  programLevel   String?  // "BACHELOR" | "MASTER" | "PHD"

  // Snapshot window
  snapshotMonth DateTime // First day of month this covers

  // Skill distribution
  topSkills      Json // [{ skill, studentCount, proficiencyAvg, demandScore, escoUri }]
  gaps           Json // [{ skill, demandScore, studentCount, severity, escoUri }]
  strengths      Json // Skills where students exceed market demand

  // Aggregate metrics
  studentCount   Int
  jobCount       Int
  gapIndex       Float // 0-100 overall gap severity
  alignmentIndex Float // 0-100 how well program aligns with market

  // Curriculum recommendations (AI-generated)
  recommendations Json? // [{ type, skill, suggestion, confidence, rationale }]

  createdAt DateTime @default(now())

  @@unique([universityName, programName, snapshotMonth])
  @@index([universityName, snapshotMonth])
  @@index([programName])
}

// ============================================
// P4 — Verified Credentials (EDC / Europass bridge)
// ============================================

// VerifiableCredential — issued credentials signed by the institution
// Covers: professor endorsements, stage completions, thesis verifications, skill attestations
model VerifiableCredential {
  id String @id @default(cuid())

  // Subject (student who holds the credential)
  subjectId String
  subjectName String // Denormalized

  // Issuer (institution)
  issuerType String // "UNIVERSITY" | "PROFESSOR" | "COMPANY"
  issuerId   String
  issuerName String // Denormalized

  // Credential content
  credentialType String // "SKILL_ENDORSEMENT" | "STAGE_COMPLETION" | "THESIS_VERIFICATION" | "PROJECT_VERIFICATION" | "DEGREE"
  schema         String @default("https://www.w3.org/2018/credentials/v1") // VC schema
  payload        Json   // The actual claim (skill, grade, hours, competencies, etc.)

  // Source — what platform record backed this credential
  sourceType String // "ProfessorEndorsement" | "StageExperience" | "Project"
  sourceId   String

  // Cryptographic proof (W3C VC spec compatible)
  proofType      String? // e.g. "Ed25519Signature2020"
  proofCreated   DateTime?
  proofValue     String?  @db.Text // The signature
  verificationMethod String? // DID or key reference

  // Status
  status     VCStatus @default(ISSUED)
  revokedAt  DateTime?
  revokedReason String?

  // Shareability
  shareToken String? @unique // Opaque token for public verification link
  viewCount  Int     @default(0)

  issuedAt  DateTime @default(now())
  expiresAt DateTime?
  createdAt DateTime @default(now())

  @@index([subjectId])
  @@index([issuerId])
  @@index([sourceType, sourceId])
  @@index([shareToken])
}

enum VCStatus {
  ISSUED
  REVOKED
  EXPIRED
  SUPERSEDED
}

// ============================================
// P6 — Company Profile (Discovery Hub)
// ============================================

// CompanyProfile — branded public profile for companies
// Parity with JobTeaser "Discover Companies" + our evidence overlay
model CompanyProfile {
  id          String @id @default(cuid())
  companyName String @unique
  slug        String @unique

  // Basic branding
  logoUrl      String?
  coverUrl     String?
  tagline      String?
  description  String? @db.Text

  // Identity
  foundedYear     Int?
  headquarters    String?
  industries      String[] @default([])
  sizeCategory    String? // "1-10", "11-50", "51-200", "201-1000", "1000+"
  websiteUrl      String?
  linkedinUrl     String?

  // Culture & values
  mission      String? @db.Text
  vision       String? @db.Text
  values       Json?   // [{ title, description, icon? }]
  cultureTags  String[] @default([])

  // International presence
  countries       String[] @default([]) // ISO 3166-1 alpha-2
  officeLocations Json?    // [{ city, country, headcount? }]

  // Rich media
  heroVideoUrl String?
  gallery      Json? // [{ url, caption, type: "image"|"video" }]

  // FAQ
  faqs Json? // [{ question, answer }]

  // Ownership / claim
  claimedBy   String? // User ID of company admin who manages this
  claimedAt   DateTime?
  verified    Boolean @default(false) // Platform-verified (email domain, etc.)

  // Follow metrics
  followerCount Int @default(0)

  // Visibility
  published Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  follows CompanyFollow[]

  @@index([slug])
  @@index([verified])
  @@index([published])
}

model CompanyFollow {
  id               String @id @default(cuid())
  companyProfileId String
  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  userId           String
  followedAt       DateTime @default(now())

  @@unique([companyProfileId, userId])
  @@index([userId])
}

// ============================================
// P7 — Self-Discovery Onboarding
// ============================================

// SelfDiscoveryProfile — populated through guided onboarding before showcasing
// Addresses HR feedback: "capire chi sei" before "mostrarti al mondo"
model SelfDiscoveryProfile {
  id        String @id @default(cuid())
  studentId String @unique

  // Step 1: Values inventory
  coreValues      String[] @default([]) // Selected from ~30 value cards
  valueRankings   Json?    // [{ value, rank, reason? }]

  // Step 2: Strengths reflection
  strengths           String[] @default([])
  strengthStories     Json?    // [{ strength, story }] short narratives
  energizingActivities String[] @default([])
  drainingActivities   String[] @default([])

  // Step 3: Past project tagging (augments existing projects)
  projectTags Json? // { projectId: { roles: [], skills: [], pride: 1-5, learnings: [] } }

  // Step 4: Career interests
  motivations         String[] @default([]) // "Impact", "Learning", "Autonomy", "Stability", "Income", ...
  dealbreakers        String[] @default([])
  idealDayNarrative   String?  @db.Text
  fiveYearNarrative   String?  @db.Text

  // Step 5: Skill self-seed (feeds skill graph)
  selfAssessedSkills  Json? // [{ skill, level 1-4, evidence? }]

  // Step 6: Self-vs-graph reconciliation
  discoveryInsights   Json? // AI-generated: gaps between self-perception and verified graph
  insightsAcknowledged Boolean @default(false)

  // Completion
  stepsCompleted     Int      @default(0) // 0-6
  completedAt        DateTime?

  // Regeneration — students can re-do this periodically
  lastRegeneratedAt  DateTime?
  regenerationCount  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
}
